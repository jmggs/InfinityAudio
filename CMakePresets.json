{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "linux-release",
      "displayName": "Linux Release (Unix Makefiles)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug (Unix Makefiles)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "ucrt64-release",
      "displayName": "Windows UCRT64 Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ucrt",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_NINJA_FORCE_RESPONSE_FILE": "ON",
        "CMAKE_C_COMPILER":   "C:/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/msys64/ucrt64/bin/ninja.exe"
      },
      "environment": {
        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;$penv{PATH}",
        "PKG_CONFIG_PATH": "C:/msys64/ucrt64/lib/pkgconfig;C:/msys64/ucrt64/share/pkgconfig"
      }
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS ARM64 Release (Bundled .app)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-mac-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt"
      }
    },
    {
      "name": "macos-x86_64-release",
      "displayName": "macOS x86_64 Release (Bundled .app)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-mac-x86_64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_PREFIX_PATH": "/usr/local/opt/qt"
      }
    }
  ],
  "buildPresets": [
    { "name": "linux-release",       "configurePreset": "linux-release"       },
    { "name": "linux-debug",         "configurePreset": "linux-debug"         },
    { "name": "ucrt64-release",      "configurePreset": "ucrt64-release"      },
    { "name": "macos-arm64-release", "configurePreset": "macos-arm64-release" },
    { "name": "macos-x86_64-release","configurePreset": "macos-x86_64-release"}
  ]
}
